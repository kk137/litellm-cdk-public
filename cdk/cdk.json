{
  "app": "npx ts-node --prefer-ts-exts bin/litellm-cdk.ts",
  "watch": {
    "include": ["**"],
    "exclude": ["README.md", "cdk*.json", "**/*.d.ts", "**/*.js", "tsconfig.json", "package*.json", "yarn.lock", "node_modules"]
  },
  "context": {
    "clusterName": "litellm-cluster",
    "projectName": "litellm",
    "litellmImage": "ghcr.io/berriai/litellm-database:v1.84.3",
    "@aws-cdk/aws-iam:minimizePolicies": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/core:target-partitions": ["aws"]
  }
}
